# 阿里云百炼 API Key（必填）
# 获取地址：https://bailian.console.aliyun.com/
ALIBABA_API_KEY=your_api_key_here

# 发票查验所用视觉模型（识别验证码 + 查验兜底）
# 推荐高精度模型，可选：qwen-vl-max / qwen-vl-plus / qwen2-vl-72b-instruct
VLM_MODEL=qwen-vl-max

# 发票识别整理所用视觉模型（PDF/图片字段提取）
# 可用轻量模型以降低成本，可选：qwen3-vl-flash / qwen-vl-plus / qwen-vl-max
RECOGNIZE_VLM_MODEL=qwen3-vl-flash

# 注意：修改以上模型配置后，需要重启服务才能生效。
# 模型名称必须是阿里云百炼平台支持的视觉语言模型（VLM）。
